{
  "name": "discord-tmux-web-launcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord-triggered OMX/OMC tmux launcher with xterm.js web viewer",
  "homepage": "https://github.com/solanian/discord-tmux-web-launcher",
  "repository": {
    "type": "git",
    "url": "https://github.com/solanian/discord-tmux-web-launcher.git"
  },
  "bugs": {
    "url": "https://github.com/solanian/discord-tmux-web-launcher/issues"
  },
  "keywords": [
    "discord",
    "tmux",
    "xtermjs",
    "typescript",
    "websocket",
    "omx",
    "claude"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "discord.js": "^14.18.0",
    "node-pty": "^1.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
